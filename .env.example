# 마케톡 환경변수 템플릿
# 실제 값은 .env 파일에 복사해 넣고, .env 는 절대 git에 올리지 마세요.

# ─── DB (Railway Postgres가 자동 주입하는 변수) ───
DATABASE_URL=postgres://user:pass@host:5432/dbname

# ─── LLM (페르소나 콘텐츠 생성) ───
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=2000

# ─── Discord Webhooks ───
DISCORD_WEBHOOK_POSTS=https://discord.com/api/webhooks/.../...
DISCORD_WEBHOOK_ADMIN=https://discord.com/api/webhooks/.../...

# ─── 서버 포트 (Railway가 자동 주입) ───
PORT=3000

# ─── 인증 (운영 환경 필수) ───
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
NODE_ENV=production

# ─── 광고 슬롯 (HTML 코드 그대로 넣기, 없으면 placeholder 표시) ───
# AD_HEAD_SCRIPT=<script async src="https://pagead2.googlesyndication.com/..."></script>
# AD_SLOT_TOP=<ins class="adsbygoogle" ...></ins><script>...</script>
# AD_SLOT_INLINE=
# AD_SLOT_BOTTOM=
# AD_SLOT_SIDE1=
# AD_SLOT_SIDE2=

# AdSense ads.txt 한 줄 그대로 (예: google.com, pub-1234567890, DIRECT, f08c47fec0942fa0)
# ADS_TXT=google.com, pub-XXXXXXXXXX, DIRECT, f08c47fec0942fa0
