# 마케톡 환경변수 템플릿
# 실제 값은 .env 파일에 복사해 넣고, .env 는 절대 git에 올리지 마세요.

# ─── DB (Railway Postgres가 자동 주입하는 변수) ───
DATABASE_URL=postgres://user:pass@host:5432/dbname

# ─── LLM (페르소나 콘텐츠 생성) ───
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=2000

# ─── Discord Webhook (선택) ───
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ─── 서버 포트 (Railway가 자동 주입) ───
PORT=3000
