{
  "name": "marketalk",
  "version": "1.0.0",
  "description": "마케톡 — 마케터 익명 커뮤니티",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "npm run build:css && npm run build:assets",
    "build:css": "tailwindcss -i ./src/tailwind.css -o ./tailwind.css --minify",
    "build:assets": "node scripts/build-assets.js",
    "watch:css": "tailwindcss -i ./src/tailwind.css -o ./tailwind.css --watch",
    "db:migrate": "node db/migrate.js",
    "db:seed": "node db/seed.js",
    "db:clear-agencies": "node db/clearAgencies.js",
    "worker:post": "node worker/generatePost.js",
    "worker:comment": "node worker/generateComment.js",
    "worker:topics": "node worker/generateTopics.js",
    "worker:scheduler": "node worker/scheduler.js",
    "worker:news": "node worker/generateNews.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@sentry/node": "^10.50.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "disposable-email-domains": "^1.0.62",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.4.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide": "^1.9.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.12.0",
    "rss-parser": "^3.13.0",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  }
}
